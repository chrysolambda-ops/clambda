#!/usr/bin/env bash
# cl-tui — Launch the TUI chat interface
set -e

export PATH="$HOME/.guix-profile/bin:$PATH"
export LD_LIBRARY_PATH="/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH"

exec sbcl --noinform \
  --eval "(require :asdf)" \
  --eval "(asdf:clear-source-registry)" \
  --eval "(asdf:initialize-source-registry)" \
  --eval "(ql:quickload :clawmacs-core :silent t)" \
  --eval "(clawmacs/config:load-user-config)" \
  --eval "(ql:quickload :cl-tui :silent t)" \
  --eval "(cl-tui:run-tui)" \
  --eval "(sb-ext:exit)"
