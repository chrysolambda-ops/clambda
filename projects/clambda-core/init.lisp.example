;;;; init.lisp.example — Example ~/.clambda/init.lisp
;;;;
;;;; Copy to ~/.clambda/init.lisp and replace placeholder credentials.

(in-package #:clambda-user)

;;; Core options
(setf *default-model* "google/gemma-3-4b")
(setf *default-max-turns* 12)
(setf *default-stream* t)
(setf *log-level* :info)
(setf *startup-message* "Clambda loaded.")

;;; Optional: SWANK for live debugging
